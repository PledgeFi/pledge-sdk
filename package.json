{
  "name": "@pledge-finance/sdk",
  "version": "1.0.0",
  "description": "TypeScript SDK for Pledge Finance on Robinhood Chain",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./deployments/*": "./src/deployments/*"
  },
  "files": [
    "dist",
    "src/deployments"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "viem": "^2.0.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "viem": "^2.31.0",
    "vitest": "^3.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pledge-finance/pledge-sdk.git"
  },
  "keywords": [
    "pledge-finance",
    "robinhood-chain",
    "defi",
    "viem"
  ],
  "engines": {
    "node": ">=18"
  }
}
